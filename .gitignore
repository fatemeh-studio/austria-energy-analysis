# ── Secrets ─────────────────────────────────────────────
# Never commit your ENTSO-E key. Share the *shape* via .env.example instead.
.env

# ── Data — re-fetchable by running notebooks/01_data_collection.ipynb ──
# Code is committed; data is regenerated. Keeps the repo lean and the
# reproducibility story clean ("clone → run 01 → data appears").
data/raw/*
data/processed/*
data/external/*
# ...but keep the folder structure so the repo clones with the right layout:
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ── Figures ──────────────────────────────────────────────
figures/qa/
!figures/qa/.gitkeep

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ── Environments ────────────────────────────────────────
# Conda env (austria-energy) lives outside the repo, so nothing to ignore
# there. These cover the case where you (or a cloner) use a local venv instead.
.venv/
venv/
env/

# ── Editor / OS cruft ───────────────────────────────────
.vscode/
.cursor/
.claude/
.idea/
.DS_Store
Thumbs.db

# personal
plans/
